{
  "consumer": {
    "name": "NotificationConsumer"
  },
  "interactions": [
    {
      "description": "a health check request",
      "providerStates": [
        {
          "name": "producer is running"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/health"
      },
      "response": {
        "body": {
          "status": "UP",
          "timestamp": "2024-01-15T10:30:00Z",
          "version": "1.0.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for a non-existent notification",
      "providerStates": [
        {
          "name": "notification notif-999 does not exist"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v1/notifications/notif-999"
      },
      "response": {
        "body": {
          "error": "Notification not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "a request for all notifications",
      "providerStates": [
        {
          "name": "notifications exist"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v1/notifications"
      },
      "response": {
        "body": {
          "notifications": [
            {
              "caseId": "DFT-2024-001",
              "id": "notif-001",
              "metadata": {
                "source": "dynamics-365",
                "version": "1.0.0"
              },
              "status": "IN_PROGRESS",
              "timestamp": "2024-01-15T10:30:00Z",
              "type": "CASE_UPDATED"
            }
          ],
          "page": 1,
          "total": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.notifications": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.notifications[*].caseId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].metadata.source": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].metadata.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.notifications[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "CASE_UPDATED|CASE_CREATED|CASE_CLOSED"
                }
              ]
            },
            "$.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for notification notif-001",
      "providerStates": [
        {
          "name": "notification notif-001 exists"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v1/notifications/notif-001"
      },
      "response": {
        "body": {
          "caseId": "DFT-2024-001",
          "id": "notif-001",
          "metadata": {
            "source": "dynamics-365",
            "version": "1.0.0"
          },
          "status": "IN_PROGRESS",
          "timestamp": "2024-01-15T10:30:00Z",
          "type": "CASE_UPDATED"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.caseId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.metadata.source": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.metadata.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "CASE_UPDATED|CASE_CREATED|CASE_CLOSED"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.4.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "NotificationProducer"
  }
}